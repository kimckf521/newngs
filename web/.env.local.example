# SMTP for partner contact form
SMTP_HOST=smtp.exmail.qq.com
SMTP_PORT=465
SMTP_USER=didihaha@nextgenscholars.asia
SMTP_PASS=
EMAIL_RECEIVER=info@nextgenscholars.asia

# Tencent CloudBase (腾讯云开发) — real auth backend.
# Leave NEXT_PUBLIC_CLOUDBASE_ENV_ID blank to keep the front-end demo auth.
# Set it (from CloudBase 控制台 → 环境 → 环境总览) to switch login/register/
# forgot-password/member over to real CloudBase auth. First enable 邮箱登录 and
# an email channel under 环境 → 登录授权.
NEXT_PUBLIC_CLOUDBASE_ENV_ID=
NEXT_PUBLIC_CLOUDBASE_REGION=ap-shanghai

# Page builder (Puck /admin) — server-side SSR reads of published content.
# On CloudBase Run the managed identity is used automatically. On other hosts
# (e.g. Vercel) set these SERVER-ONLY secrets (NOT NEXT_PUBLIC) or published
# content won't render. Guard this long-lived Tencent secret.
CLOUDBASE_SECRET_ID=
CLOUDBASE_SECRET_KEY=

# PostgreSQL — the real backend for members/roles, courses (and later pages).
# The CloudBase env is the NEW generation (SQL 型数据库 = PostgreSQL), so the app
# persists to plain Postgres, not the document DB. Leave DATABASE_URL blank to
# keep the localStorage/demo trial mode (zero backend; local dev works as-is).
# To go live:
#   1. CloudBase 控制台 → SQL 型数据库 → 账号管理 → 创建账号 (a DB user + password).
#   2. For access from OUTSIDE CloudBase (local dev / Vercel) → 连接设置 → 开启
#      外网 IPv4, and add the caller's IP to the whitelist. NOTE: Vercel's egress
#      IPs are dynamic → you must allow 0.0.0.0/0 (a static-IP host like the
#      Tencent server only needs its one IP — more secure). On CloudBase Run use
#      the INTERNAL address (no external/whitelist needed).
#   3. Set DATABASE_URL below. The app auto-creates its tables on first use
#      (see db/schema.sql for the DDL).
# Format: postgresql://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=
# SSL: this CloudBase external SQL endpoint does NOT support TLS — keep PGSSL=0
# (or unset). Setting PGSSL=1 here fails with "server does not support SSL".
PGSSL=0

# Shared secret gating the admin API (members + course writes), sent by the
# console as the x-admin-key header. If blank, the routes are open OUTSIDE
# production only; ALWAYS set this before deploying. Use a long random string.
ADMIN_API_KEY=

# Dev-only: force-allow the /admin editor locally (skips the admins check).
# Ignored in production builds. Never set this in a deployed build.
# NEXT_PUBLIC_ADMIN_DEV_BYPASS=1

# AI advisor chat (the "咨询顾问" widget). Backend is chosen in
# lib/chat/provider.ts:
#  • PROD (CloudBase Run): the native CloudBase AI gateway (生文模型) via
#    app.ai() — authenticated by the Run managed identity. NO key needed; just
#    开通 (enable) the model in 控制台 → AI → 生文模型. Optionally override the
#    model without a rebuild (defaults in lib/env.ts):
# CLOUDBASE_AI_PROVIDER=deepseek
# CLOUDBASE_AI_MODEL=deepseek-v3.2
#  • LOCAL DEV / off-platform (no CloudBase creds): falls back to the direct
#    DeepSeek API. SERVER-ONLY secret (NOT NEXT_PUBLIC), used only by /api/chat,
#    never sent to the browser. Get one at https://platform.deepseek.com.
#    Without any backend the chat shows the "reach us on WeChat" fallback.
DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# WeCom (企业微信) live-chat relay — "转人工顾问" pushes visitor messages to staff
# in WeCom, and their replies route back to the visitor's web widget (no QR).
# Leave blank to keep the built-in /admin/inbox web console as the handoff.
# Create a self-built app: 企业微信管理后台 → 应用管理 → 自建 → 创建应用. Then:
#  - WECOM_CORP_ID:   我的企业 → 企业信息 → 企业ID
#  - WECOM_AGENT_ID / WECOM_SECRET: the app's AgentId + Secret
#  - WECOM_TOKEN / WECOM_AES_KEY: 应用 → 接收消息 → API接收消息 (set the callback
#    URL to https://<your-domain>/api/wecom/callback, randomly generate Token +
#    EncodingAESKey, and add the server's egress IP to the app's 企业可信IP).
#  - WECOM_AGENT_USERS: comma-separated staff UserIDs to notify (e.g. zhangsan,lisi)
# All SERVER-ONLY (never NEXT_PUBLIC). On CloudBase Run set them as service env vars.
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_SECRET=
WECOM_TOKEN=
WECOM_AES_KEY=
WECOM_AGENT_USERS=
