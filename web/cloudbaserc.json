{
  "version": "2.0",
  "envId": "ngs-d7gnop4sfa66322e9",
  "framework": {
    "name": "nextgen-scholars",
    "plugins": {
      "container": {
        "use": "@cloudbase/framework-plugin-container",
        "inputs": {
          "serviceName": "ngs-web",
          "servicePath": "/",
          "localPath": "./",
          "uploadType": "package",
          "dockerfilePath": "./Dockerfile",
          "buildDir": "./",
          "containerPort": 3000,
          "cpu": 0.5,
          "mem": 1,
          "minNum": 1,
          "maxNum": 5,
          "isPublic": true,
          "envVariables": {
            "NODE_ENV": "production",
            "SMTP_HOST": "smtp.exmail.qq.com",
            "SMTP_PORT": "465",
            "EMAIL_RECEIVER": "info@nextgenscholars.asia"
          }
        }
      }
    }
  }
}
